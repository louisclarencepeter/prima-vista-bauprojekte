# Anthropic API key for the /api/chat endpoint (Netlify function + Vite dev middleware)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key for the /api/contact and /api/blitz endpoints
# Get one at https://resend.com/api-keys
RESEND_API_KEY=re_...

# Sender address — must be on a domain verified in your Resend dashboard.
# Format can be `name@domain` or `"Name <name@domain>"`.
MAIL_FROM=Prima Vista Bauprojekte <noreply@primavista-bauprojekte.com>

# Where form submissions are delivered.
MAIL_TO_OFFICE=office@primavista-bauprojekte.com

# MongoDB Atlas M0 connection for the blog/admin system.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=prima_vista

# JWT secret for the admin httpOnly cookie.
JWT_SECRET=replace-with-a-long-random-string

# Used only by `npm run seed:admin`; do not commit real credentials.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Optional Google admin login. Use the same OAuth client ID in both vars.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
ADMIN_GOOGLE_EMAIL=admin@example.com

# Optional Google reviews integration. Without these, the homepage uses the
# local fallback testimonial.
GOOGLE_PLACES_API_KEY=...
GOOGLE_PLACE_ID=...
